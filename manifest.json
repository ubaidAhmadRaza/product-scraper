{
  "manifest_version": 3,
  "name": "Product Extractor Pro",
  "version": "1.0.0",
  "description": "Auto-extract product IDs and WhatsApp numbers across paginated tables with deduplication",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://xyz/*",
    "https://*.xyz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Product Extractor Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://xyz/products",
        "https://xyz/products?*",
        "https://xyz/products/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}